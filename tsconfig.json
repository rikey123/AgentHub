{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals"],
    "jsx": "react-jsx"
  },
  "files": [
    "playwright.config.ts",
    "vitest.config.ts"
  ],
  "include": ["apps/cli/**/*.ts", "apps/cli/**/*.tsx", "packages/**/*.ts", "packages/**/*.tsx"],
  "exclude": ["apps/web", "**/dist", "**/build", "**/node_modules"]
}
