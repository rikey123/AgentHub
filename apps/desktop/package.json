{
  "name": "@agenthub/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.cjs",
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run build:bootstrap && pnpm run build:daemon",
    "build:bootstrap": "node write-main-bootstrap.mjs",
    "build:daemon": "tsc -p tsconfig.daemon.json && node esbuild.daemon.mjs",
    "package:resources": "node prepare-package-resources.mjs",
    "package:prepare": "pnpm --filter @agenthub/web build && pnpm run build && pnpm run package:resources",
    "dist": "pnpm run package:prepare && electron-builder --win nsis",
    "package:dir": "pnpm run package:prepare && electron-builder --win dir",
    "dev": "pnpm run build && electron .",
    "start": "electron .",
    "test": "vitest run --root ../.. apps/desktop/test/desktop.test.ts",
    "test:origin": "vitest run --root ../.. apps/desktop/test/origin.integration.test.ts"
  },
  "devDependencies": {
    "@agenthub/daemon": "workspace:*",
    "esbuild": "^0.27.2",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "electron-builder-squirrel-windows": "^26.15.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "electron-updater": "^6.8.9"
  }
}
