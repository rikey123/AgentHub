{
  "name": "@agenthub/mobile",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "test": "vitest run --root ../.. apps/mobile/src",
    "cap:add:android": "cap add android",
    "cap:sync": "pnpm run build && cap sync android && node scripts/patch-android-manifest.mjs",
    "cap:open:android": "cap open android",
    "android:run": "pnpm run cap:sync && cap run android",
    "android:debug-apk": "pnpm run cap:sync && cd android && gradlew.bat assembleDebug",
    "android:apk": "pnpm run android:debug-apk"
  },
  "dependencies": {
    "@agenthub/protocol": "workspace:*",
    "@agenthub/sdk": "workspace:*",
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "vite": "^6.3.0"
  }
}
